{
  "printWidth": 180,                
  "tabWidth": 2,                    
  "semi": true,                    
  "singleQuote": false,            
  "quoteProps": "as-needed",       
  "jsxSingleQuote": false,         
  "trailingComma": "none",         
  "bracketSpacing": true,          
  "jsxBracketSameLine": false,      
  "arrowParens": "always",         
  "rangeStart": 0,                 
  "requirePragma": false,          
  "insertPragma": false,            
  "proseWrap": "preserve",          
  "htmlWhitespaceSensitivity": "css",
  "vueIndentScriptAndStyle": false,
  "endOfLine": "lf",               
  "embeddedLanguageFormatting": "auto"
}